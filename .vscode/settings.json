{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.workingDirectories": ["./apps/web"],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "astro"
  ],
  "stylelint.validate": ["css", "astro"],
  "cssVariables.lookupFiles": ["apps/web/src/styles/**/*.css"],
  "cssVariables.blacklistFolders": [
    "**/node_modules",
    "**/dist",
    "**/.astro",
    "**/.git"
  ]
}
